              "raw": "{\n  \"userId\": \"{{USER_ID}}\",\n  \"mood\": \"Happy\",\n  \"stressLevel\": 5,\n  \"sleepHours\": 8,\n  \"notes\": \"Feeling great today!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/assessment/add",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "assessment", "add"]
